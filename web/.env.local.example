# Backend API URL (Render URL for production)
NEXT_PUBLIC_API_URL=https://your-backend.onrender.com/api/v1

# WhatsApp number (with country code, no spaces/dashes)
# Example: 5511999999999 (Brazil +55, DDD 11, number)
NEXT_PUBLIC_WHATSAPP_NUMBER=5511999999999

# Store name for WhatsApp messages and SEO
NEXT_PUBLIC_STORE_NAME=Fitness Store

# Site URL for SEO metadata (canonical/Open Graph)
NEXT_PUBLIC_SITE_URL=https://wamodafitness.com.br
