# ============================================================
# CONFIGURAÇÃO DO BOT WHATSAPP
# Copie este arquivo para .env e preencha os valores
# ============================================================

# URL do backend FastAPI (localhost em dev, URL pública em prod)
BACKEND_URL=http://localhost:8000

# Token secreto compartilhado entre o bot e o backend
# Defina o mesmo valor em backend/.env como WHATSAPP_BOT_TOKEN
BOT_TOKEN=mude-esse-token-antes-de-usar

# Tenant ID da sua loja (padrão: 1)
TENANT_ID=1

# Número de telefone do bot (apenas para referência, não obrigatório)
# Formato: 5511999999999 (código país + DDD + número, sem espaços)
BOT_NUMBER=

# Pasta para salvar a autenticação Baileys (evita scanear QR toda vez)
AUTH_FOLDER=./auth_info

# Porta HTTP do servidor /send (usado pelo backend para enviar mensagens proativamente)
# O backend deve ter WHATSAPP_BOT_URL=http://localhost:3000 no seu .env
SEND_PORT=3000
